# ============================================================
# AI City Backend — Required Environment Variables
# Copy to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ── Database ─────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5433
DB_NAME=promptforge
DB_USER=promptforge
DB_PASSWORD=<your-db-password>           # REQUIRED — no fallback

# ── JWT Authentication ───────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=<your-jwt-secret-key>         # REQUIRED — must be cryptographically random

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no spaces)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Ollama (RAG embeddings) ──────────────────────────────────
OLLAMA_URL=http://localhost:11434

# ── Qdrant (Vector database) ─────────────────────────────────
QDRANT_URL=http://localhost:6333

# ── Matomo Analytics ─────────────────────────────────────────
MATOMO_URL=http://localhost:8080
MATOMO_SITE_ID=1
MATOMO_API_TOKEN=

# ── Payment Providers ────────────────────────────────────────
VIETQR_PARTNER_ID=
VIETQR_PARTNER_KEY=
VIETQR_BANK_CODE=VCB
MOMO_PARTNER_CODE=
MOMO_API_KEY=
ZALOPAY_APP_ID=
ZALOPAY_KEY1=
ZALOPAY_KEY2=
